{
  "name": "reports-service",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && swc src -d dist/app",
    "lint": "eslint . --ext .ts",
    "lint:fix": "npm run lint -- --fix",
    "dev": "tsx watch --inspect src/index.ts",
    "start": "node dist/app/src/index.js",
    "test": "jest test/*/*.test.ts",
    "render-dashboards": "cross-env LOG_LEVEL=debug CLICKHOUSE_URL=clickhouse-data-platform.data-platform/highlander tsx tools/render-dashboards.ts",
    "render-dashboards-dev": "cross-env LOG_LEVEL=debug CLICKHOUSE_URL=clickhouse/highlander tsx tools/render-dashboards.ts",
    "render-dashboards-staging": "cross-env LOG_LEVEL=debug CLICKHOUSE_URL=clickhouse-data-platform.data-platform:8123/highlander tsx tools/render-dashboards.ts",
    "release-dashboards": "cross-env LOG_LEVEL=debug SUPERSET_URL=https://dashboards.data-us-east4.production.universe.engineer SUPERSET_USERNAME=platform+superset@universe.com tsx tools/release-dashboards.ts",
    "release-dashboards-dev": "cross-env LOG_LEVEL=debug CLICKHOUSE_PASSWORD=password SUPERSET_URL=http://localhost:8088 SUPERSET_USERNAME=admin SUPERSET_PASSWORD=admin tsx tools/release-dashboards.ts",
    "release-dashboards-staging": "cross-env LOG_LEVEL=debug SUPERSET_URL=https://dashboards.staging.universe.com SUPERSET_USERNAME=universe SUPERSET_PASSWORD=changeme tsx tools/release-dashboards.ts",
    "export": "cross-env LOG_LEVEL=debug tsx tools/export-assets.ts",
    "export-dev": "cross-env LOG_LEVEL=debug SUPERSET_URL=http://localhost:8088 SUPERSET_USERNAME=admin SUPERSET_PASSWORD=admin tsx tools/export-assets.ts"
  },
  "author": "",
  "license": "ISC",
