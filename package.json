    "@opentelemetry/exporter-trace-otlp-grpc": "^0.50.0",
    "@opentelemetry/sdk-metrics": "^1.20.0",
    "@opentelemetry/sdk-node": "^0.50.0",
    "@sentry/node": "^7.99.0",
    "@universe/api": "1.27.0",
    "express": "^4.18.2",
    "google-protobuf": "^3.21.2",
    "nice-grpc": "^2.1.0",
    "nice-grpc-common": "^2.0.2",
    "nice-grpc-opentelemetry": "^0.1.13",
    "nice-grpc-prometheus": "^0.2.0",
    "nice-grpc-server-health": "^2.0.4",
    "nice-grpc-server-reflection": "^2.0.6",
    "pino": "^8.18.0",
    "protobufjs": "^7.2.6",
    "superset-openapi": "git://github.com/uniiverse/superset-openapi.git"
  },
  "devDependencies": {
    "@swc/cli": "^0.3.0",
    "@swc/core": "^1.4.12",
    "@types/archiver": "^6.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "archiver": "^6.0.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
