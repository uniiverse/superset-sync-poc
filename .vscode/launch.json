{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to process",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "address": "127.0.0.1",
      "localRoot": "${workspaceFolder}/src",
      "remoteRoot": "/app/src",
      "skipFiles": [
          // Node.js internal core modules
          "<node_internals>/**",

          // Ignore all dependencies (optional)
          "${workspaceFolder}/node_modules/**",
      ],
    }
  ]
}